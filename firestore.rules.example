rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function ownsUserDoc(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if signedIn();

      allow create: if ownsUserDoc(userId) &&
        request.resource.data.role == 'user';

      allow update: if ownsUserDoc(userId) &&
        request.resource.data.role == resource.data.role;

      allow delete: if false;
    }

    match /scanned_products/{productId} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    match /submissions/{submissionId} {
      allow create: if signedIn() &&
        request.resource.data.contributorUid == request.auth.uid;

      allow read: if isAdmin() || (
        signedIn() && resource.data.contributorUid == request.auth.uid
      );

      allow update, delete: if isAdmin();
    }
  }
}
